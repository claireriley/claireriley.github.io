---
interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<article
  class:list={[
    // Base
    "prose max-w-none",

    // Body
    "prose-p:leading-relaxed prose-p:text-foreground",

    // Heading
    "prose-headings:font-semibold prose-headings:tracking-tight prose-headings:text-foreground",
    "prose-h1:text-2xl prose-h2:text-xl prose-h3:text-lg",
    "prose-h4:text-destructive prose-h5:text-destructive prose-h6:text-destructive", // We only use h1 to h3

    // Anchor
    "prose-a:text-foreground prose-a:decoration-muted-foreground/50 prose-a:underline-offset-2 prose-a:transition-colors prose-a:duration-200 prose-a:ease-out prose-a:hover:decoration-muted-foreground",

    // Image
    "prose-img:cursor-zoom-in prose-img:rounded-sm prose-img:shadow-lg prose-img:transition-all prose-img:duration-200 prose-img:ease-out prose-img:hover:scale-[1.01]",

    // List, markers, blockquote, strong, horizontal line
    "prose-ol:text-foreground prose-ul:text-foreground",
    "prose-li:marker:text-foreground/80",
    "prose-blockquote:border-l-border/50 prose-blockquote:text-muted-foreground prose-blockquote:italic",
    "prose-strong:text-foreground",
    "prose-hr:my-8 prose-hr:border-0 prose-hr:border-t prose-hr:border-t-border/50",

    // Table
    "prose-thead:border-b-2 prose-thead:border-foreground/20 prose-thead:font-medium prose-th:text-sm prose-th:text-foreground",
    "prose-tr:border-b prose-tr:border-border/50",
    "prose-td:text-foreground",

    // Inline code
    "prose-code:rounded-sm prose-code:bg-muted/80 prose-code:px-1.5 prose-code:py-0.5 prose-code:font-mono prose-code:text-foreground prose-code:before:content-none prose-code:after:content-none",
    className,
  ]}
>
  <slot />
</article>
