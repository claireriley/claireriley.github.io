---
import { Icon } from "astro-icon/components"

interface Props {
  label: string
  href: string
  class?: string
}

const { label, href, class: className } = Astro.props
---

<a
  href={href}
  class:list={["group inline-flex items-center gap-x-1.5", className]}
>
  <Icon
    name="ph:arrow-left"
    size={16}
    class="text-muted-foreground transition-all duration-200 ease-out group-hover:-translate-x-0.5 group-hover:text-foreground"
  />
  <span>{label}</span>
</a>
