---
import { Icon } from "astro-icon/components"

interface Props {
  type?: "tip" | "note" | "warning" | "caution" | "important"
  title?: string
}

const { type = "note", title } = Astro.props

const config = {
  tip: {
    icon: "ph:lightbulb-fill",
    label: "Tip",
  },
  note: {
    icon: "ph:info-fill",
    label: "Note",
  },
  warning: {
    icon: "ph:warning-fill",
    label: "Warning",
  },
  caution: {
    icon: "ph:seal-warning-fill",
    label: "Caution",
  },
  important: {
    icon: "ph:star-fill",
    label: "Important",
  },
}

const { icon, label } = config[type]
const displayTitle = title ?? label
---

<div class={`callout-${type} my-4 border-l-4 py-1 pl-4`}>
  <div class="mb-1 flex items-center gap-2">
    <Icon name={icon} class="size-4 shrink-0 text-muted-foreground/80" />
    <span class="font-semibold text-foreground">{displayTitle}</span>
  </div>
  <div class="text-foreground">
    <slot />
  </div>
</div>

<style>
  .callout-tip {
    border-color: var(--color-tip);
  }
  .callout-note {
    border-color: var(--color-note);
  }
  .callout-warning {
    border-color: var(--color-warning);
  }
  .callout-caution {
    border-color: var(--color-caution);
  }
  .callout-important {
    border-color: var(--color-important);
  }
</style>
