---
import { type CollectionEntry, render } from "astro:content"

import WritingPage from "@layouts/pages/WritingPage.astro"
import { getWritings } from "@utils/getContent"

export async function getStaticPaths() {
  const writingEntries = getWritings()

  return (await writingEntries).map((writingEntry) => ({
    params: { id: writingEntry.id },
    props: { writingEntry },
  }))
}

interface Props {
  writingEntry: CollectionEntry<"writings">
}

const { writingEntry } = Astro.props
const { Content, remarkPluginFrontmatter } = await render(writingEntry)
---

<WritingPage
  frontmatter={writingEntry}
  readingTime={remarkPluginFrontmatter.minutesRead}
>
  <Content />
</WritingPage>
